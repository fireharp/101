# Copy to .env and fill in.
PORT=4000
DATABASE_PATH=./data/drill.db
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_TRANSCRIPTION_LANGUAGE=
OPENAI_GRADING_MODEL=gpt-4.1-mini
REALTIME_VOICE=echo
# Optional: realtime voice speed, clamped to [0.25, 1.5]. Higher = faster.
# OPENAI_REALTIME_VOICE_SPEED=1.25
# Optional: retry budget for the OpenAI client_secrets mint on retryable errors.
# OPENAI_REALTIME_TOKEN_ATTEMPTS=3
# Optional: use a server-side prompt from the OpenAI Prompt Library instead
# of inlining DRILL_COACH_INSTRUCTIONS.
OPENAI_REALTIME_PROMPT_ID=
OPENAI_REALTIME_PROMPT_VERSION=
FRONTEND_ORIGIN=http://localhost:5173
# Set to "1" to use deterministic keyword-based grading instead of LLM grading.
USE_OFFLINE_GRADER=0

# Optional side-by-side ElevenLabs Agents voice provider. Set the API key,
# then run `pnpm elevenlabs:setup`; the script writes ELEVENLABS_AGENT_ID.
VOICE_PROVIDER=openai
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_NAME=Drill Coach (dev)
ELEVENLABS_VOICE_ID=
ELEVENLABS_LLM_MODEL=gpt-5.2

# Optional: only needed for the Layer-4 resource extraction CLI
# (`pnpm extract:resources`). Without it, GitHub API is capped at 60 req/hr;
# any `repo` or `public_repo` scope token lifts it to 5000/hr.
# GITHUB_TOKEN=
